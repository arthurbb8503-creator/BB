  document.getElementById('tab-'+tab).classList.add('active');
  document.querySelectorAll('.tab-btn').forEach(b=>{if((tab==='g'&&b.textContent.includes('Competências'))||(tab==='eng'&&b.textContent.includes('Engajamento'))||(tab==='resumo'&&b.textContent.includes('Resumo')))b.classList.add('active');});
  if(el&&el.classList&&el.classList.contains('sb-item'))el.classList.add('active');
  if(!el){
    const firstGroupItems=document.querySelectorAll('.sidebar .sb-group:first-child .sb-item');
    if(tab==='g'&&firstGroupItems[0])firstGroupItems[0].classList.add('active');
    if(tab==='eng'&&firstGroupItems[1])firstGroupItems[1].classList.add('active');
    if(tab==='resumo'&&firstGroupItems[2])firstGroupItems[2].classList.add('active');
  }
}
function jumpTo(tab,id){goTab(tab,null);setTimeout(()=>{const e=document.getElementById(`${tab}-${id}`);if(e)e.scrollIntoView({behavior:'smooth',block:'start'});},60);}
function saveEng(){
  ENG.items.forEach((_,i)=>{
    E[`act|${i}`]=document.getElementById(`eng-act-${i}`).value;
    E[`date|${i}`]=document.getElementById(`eng-date-${i}`).value;
  });
  persist();
}
function saveObs(tab,id,val){
  O[`${tab}|${id}`]=val||'';
  persist();
}

function persist(){
  try{
    localStorage.setItem('ac26i',JSON.stringify({
      func:document.getElementById('i-func').value,
      prefixo:document.getElementById('i-prefixo').value,
      lider:document.getElementById('i-lider').value,
      periodo:document.getElementById('i-periodo').value
    }));
    localStorage.setItem('ac26s',JSON.stringify(S));
    localStorage.setItem('ac26e',JSON.stringify(E));
    localStorage.setItem('ac26o',JSON.stringify(O));
  }catch(e){}
}
function load(){
  try{
    const info=JSON.parse(localStorage.getItem('ac26i')||'{}');
    ['func','prefixo','lider','periodo'].forEach(k=>{if(info[k])document.getElementById('i-'+k).value=info[k];});
    const saved=JSON.parse(localStorage.getItem('ac26s')||'{}');Object.assign(S,saved);
    Object.keys(S).forEach(k=>{
      const v=S[k];if(!v)return;
      const[tab,id,iStr,type]=k.split('|');const i=parseInt(iStr);
      const comp=(COMPS[tab]||[]).find(c=>c.id===id);if(!comp||i>=comp.rows.length)return;
      const sel=document.getElementById(`sel-${tab}-${id}-${i}-${type}`);
      if(sel){sel.value=FREQS[v];sel.className='fsel s'+v;
        const chip=document.getElementById(`chip-${tab}-${id}-${i}-${type}`);
        if(chip){chip.textContent=v;chip.className='chip s'+v;}
        if(type==='lider'){const or=document.getElementById(`or-${tab}-${id}-${i}`);const txt=comp.rows[i][1];const row=document.getElementById(`row-${tab}-${id}-${i}`);if(v<3&&txt){or.textContent=txt;or.className='td-o';if(row)row.classList.add('flagged');}}
      }
    });
    const eng=JSON.parse(localStorage.getItem('ac26e')||'{}');Object.assign(E,eng);
    ENG.items.forEach((_,i)=>{
      const ta=document.getElementById(`eng-act-${i}`); const dt=document.getElementById(`eng-date-${i}`);
      if(ta && E[`act|${i}`]) ta.value=E[`act|${i}`];
      if(dt && E[`date|${i}`]) dt.value=E[`date|${i}`];
    });
    const obs=JSON.parse(localStorage.getItem('ac26o')||'{}');Object.assign(O,obs);
    COMPS.g.forEach(c=>{
      const ta=document.getElementById(`obs-g-${c.id}`);
      if(ta && O[`g|${c.id}`]) ta.value=O[`g|${c.id}`];
    });
    COMPS.g.forEach(c=>recalc('g',c.id));refreshSb();refreshR();
  }catch(e){}
}
function resetAll(){
  if(!confirm('Limpar todas as avaliações, ações e observações registradas? Esta ação não pode ser desfeita.'))return;
  Object.keys(S).forEach(k=>delete S[k]);
  Object.keys(E).forEach(k=>delete E[k]);
  Object.keys(O).forEach(k=>delete O[k]);
  document.querySelectorAll('.fsel').forEach(s=>{s.value='';s.className='fsel';});
  document.querySelectorAll('.chip').forEach(c=>{c.textContent='—';c.className='chip';});
  document.querySelectorAll('.td-o').forEach(o=>o.className='td-o empty');
  document.querySelectorAll('tbody tr').forEach(r=>r.classList.remove('flagged'));
  document.querySelectorAll('.eng-ta,.eng-date,.comp-obs-ta').forEach(e=>e.value='');
  COMPS.g.forEach(c=>recalc('g',c.id));refreshSb();refreshR();
  try{localStorage.removeItem('ac26s');localStorage.removeItem('ac26e');localStorage.removeItem('ac26o');}catch(e){}
}
buildAll();load();
</script>
