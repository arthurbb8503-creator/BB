function refreshR(){
  const el=document.getElementById('r-g');
  el.innerHTML='';const aArr=[],lArr=[];
  COMPS.g.forEach(comp=>{
    const a=avg(comp.rows.map((_,i)=>gv('g',comp.id,i,'auto')));
    const l=avg(comp.rows.map((_,i)=>gv('g',comp.id,i,'lider')));
    aArr.push(a);lArr.push(l);
    const diff=(a&&l)?l-a:null;const dc=diff===null?'':diff>0?'pos':diff<0?'neg':'zer';
    el.innerHTML+=`<div class="rrow"><span class="rr-n">${comp.icon} ${comp.label}</span><div class="rr-s"><span class="rr-chip rc-auto">${a||'—'}</span><span class="rr-chip rc-lider">${l||'—'}</span>${diff!==null?`<span class="rr-diff ${dc}">${diff>0?'+':''}${diff}</span>`:''}</div></div>`;
  });
  const ta=avg(aArr.filter(v=>v>0)),tl=avg(lArr.filter(v=>v>0));
  const td=(ta&&tl)?tl-ta:null;
  el.innerHTML+=`<div class="rrow rtotal"><span class="rr-n" style="font-weight:800">Nota da Seção</span><div class="rr-s"><span class="rr-chip rc-auto" style="font-weight:800">${ta||'—'}</span><span class="rr-chip rc-lider" style="font-weight:800">${tl||'—'}</span>${td!==null?`<span class="rr-diff ${td>0?'pos':td<0?'neg':'zer'}">${td>0?'+':''}${td}</span>`:''}</div></div>`;
  document.getElementById('rf-auto').textContent=ta||'—';
  document.getElementById('rf-lider').textContent=tl||'—';
  document.getElementById('rf-nivel').textContent=tl?NIVEL[tl]:'Preencha as avaliações para obter a nota final.';
}
