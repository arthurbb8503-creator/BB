function recalc(tab,id){
  const comp=COMPS[tab].find(c=>c.id===id);
  const a=avg(comp.rows.map((_,i)=>gv(tab,id,i,'auto')));
  const l=avg(comp.rows.map((_,i)=>gv(tab,id,i,'lider')));
  ['auto','lider'].forEach(t=>{const v=t==='auto'?a:l;const sh=document.getElementById(`sh-${tab}-${id}-${t}`);const cf=document.getElementById(`cf-${tab}-${id}-${t}`);if(sh)sh.textContent=v||'—';if(cf)cf.textContent=v||'—';});
  const d=document.getElementById(`cf-${tab}-${id}-desc`);if(d)d.textContent=l?`· ${NL[l]}`:'';
  const sb=document.getElementById(`sb-${tab}-${id}`);if(sb)sb.textContent=l||'—';
}
function refreshSb(){
  const gL=COMPS.g.map(c=>avg(c.rows.map((_,i)=>gv('g',c.id,i,'lider'))));
